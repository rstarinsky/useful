<?php
// за основу взято скрипт от aiogram

// ——— Преобразует Telegram text + entities в HTML (offsets/length заданы в UTF-16 code units) ———
function entitiesToHtml($text, $entities) {
    if (!$text || !$entities) {
        return htmlspecialchars($text, ENT_QUOTES, 'UTF-8');
    }
    
    // Строим карту UTF-16 → UTF-8
    $map = buildUtf16ToUtf8Map($text);
    
    // Собираем все части в массив
    $parts = unparseEntities($text, $entities, $map);
    
    return implode('', $parts);
}
// Рекурсивная функция обработки entities
function unparseEntities($text, $entities, $map, $offset = 0, $length = 0) {
    if (!$length) {
        // mb_strlen($text) не сработает, т.к. если в строке есть emoji,
        // то длина $text будет больше и нужно брать длину из $map
        $length = array_key_last($map);
    }
    
    $parts = [];
    
    foreach ($entities as $index => $entity) {
        $entityOffset = $entity['offset'];
        $entityLength = $entity['length'];
        
        // Пропускаем entities до нашего offset
        if ($entityOffset < $offset) {
            continue;
        }
        
        // Добавляем текст ДО entity (используем карту для байтовых позиций)
        if ($entityOffset > $offset) {
            $startByte = $map[$offset]; $endByte = $map[$entityOffset];
            $before = substr($text, $startByte, $endByte - $startByte);
            $parts[] = htmlspecialchars($before, ENT_QUOTES, 'UTF-8');
        }
        
        // Границы текущего entity
        $start = $entityOffset;
        $end = $entityOffset + $entityLength;
        
        // Находим вложенные entities
        $subEntities = [];
        for ($i = $index + 1; $i < count($entities); $i++) {
            $subEntity = $entities[$i];
            // Если entity внутри текущего
            if ($subEntity['offset'] < $end) {
                $subEntities[] = $subEntity;
            } else {
                break;
            }
        }
        
        // Получаем текст entity через карту
        $startByte = $map[$start]; $endByte = $map[$end];
        $inner = substr($text, $startByte, $endByte - $startByte);
        
        // Рекурсивно обрабатываем вложенные
        if ($subEntities) {
            $entityText = implode('', unparseEntities($text, $subEntities, $map, $start, $end));
        } else {
            $entityText = htmlspecialchars($inner, ENT_QUOTES, 'UTF-8');
        }
        
        // Применяем тег
        $parts[] = entityApplyTag($entity, $entityText, $inner);
        
        // Обновляем offset
        $offset = $end;
    }
    
    // Добавляем оставшийся текст
    if ($offset < $length) {
        $startByte = $map[$offset]; $endByte = $map[$length];
        $rest = substr($text, $startByte, $endByte - $startByte);
        $parts[] = htmlspecialchars($rest, ENT_QUOTES, 'UTF-8');
    }
    
    return $parts;
}
// Применяет HTML тег к тексту entity сущности
function entityApplyTag($entity, $safe, $inner) {
    $wrapped = '';

    switch ($entity['type']) {
        case 'bold'          : $wrapped = "<b>$safe</b>"; break;
        case 'italic'        : $wrapped = "<i>$safe</i>"; break;
        case 'underline'     : $wrapped = "<u>{$safe}</u>"; break;
        case 'strikethrough' : $wrapped = "<s>{$safe}</s>"; break;
        case 'spoiler'       : $wrapped = "<tg-spoiler>{$safe}</tg-spoiler>"; break;
        case 'code'          : $wrapped = "<code>{$safe}</code>"; break;
        case 'pre'           : $wrapped = '<pre'.(!empty($entity['language']) ? ' data-lang="'.htmlspecialchars($entity['language']).'"' : '').'>'.$safe.'</pre>'; break;
        case 'blockquote'    : $wrapped = "<blockquote>{$safe}</blockquote>"; break;
        case 'text_link'     : $wrapped = "<a href=\"".htmlspecialchars($entity['url'])."\">$safe</a>"; break;
        case 'text_mention'  : $wrapped = '<a href="tg://user?id='.(int)$entity['user']['id'].'">'.$safe.'</a>'; break;
        case 'mention'       : $wrapped = '<a href="https://t.me/' . ltrim($safe, '@') . '">'.$safe.'</a>'; break;
        case 'url'           : $wrapped = '<a href="'.$safe.'">'.$safe.'</a>'; break;
        case 'email'         : $wrapped = '<a href="mailto:'.$safe.'">'.$safe.'</a>'; break;
        case 'phone_number'  : $wrapped = '<a href="tel:'.preg_replace('/[^+\d]/', '', $inner).'">'.$safe.'</a>'; break;

        default: $wrapped = $safe;
    }

    return $wrapped;
}
// Строит карту соответствия UTF-16 code unit index → UTF-8 byte offset
function buildUtf16ToUtf8Map($text) {
    $map = [0 => 0];
    $unitIndex = 0;
    $byteOffset = 0;

    foreach (preg_split('//u', $text, -1, PREG_SPLIT_NO_EMPTY) as $ch) {
        $utf8len = strlen($ch);              // 1..4 байта
        $units   = ($utf8len >= 4) ? 2 : 1;  // surrogate pair = 2 UTF-16 units
        $unitIndex += $units;
        $byteOffset += $utf8len;
        $map[$unitIndex] = $byteOffset;
    }

    return $map;
}
